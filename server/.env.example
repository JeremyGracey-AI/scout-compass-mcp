# Scout Compass MCP server — environment variables
# Copy to .env (gitignored) or export in your shell. ALL IQ vars are optional:
# with FOUNDRY_IQ_ENDPOINT unset, the server exposes exactly the 9 governed-loop
# tools and the vault loop is byte-for-byte unchanged. IQ only ever adds a tool.

# --- Core (existing) ---
VAULT_PATH=/Users/jghome/GitHub/scout-compass/vault
PORT=3000
# MODE=http            # set for streamable HTTP on :PORT/mcp (Foundry). Unset = stdio.

# --- Foundry IQ grounding (Path B: ground_foundry_iq) ---
# When FOUNDRY_IQ_ENDPOINT is set, the server registers the read-only
# `ground_foundry_iq` tool (10 tools total). It calls the Azure AI Search
# knowledge base /retrieve action over raw fetch — no Azure SDK, no new deps.
#
# Use a READ-ONLY query key, never an admin key. The tool only ever retrieves.
FOUNDRY_IQ_ENDPOINT=https://<your-search-service>.search.windows.net
FOUNDRY_IQ_KEY=<azure-ai-search-QUERY-key>
FOUNDRY_IQ_KB=scout-compass-kb
# Optional overrides:
# FOUNDRY_IQ_API_VERSION=2026-05-01-preview   # default
# FOUNDRY_IQ_KS=atlas-handbook-ks             # pin one knowledge source (name)
# FOUNDRY_IQ_KS_KIND=file                     # its kind: file | azureBlob | searchIndex | web | ...

# --- Fabric IQ grounding (Path B sibling: ground_fabric_iq) ---
# Registers ground_fabric_iq when FABRIC_IQ_KS is set. By default it rides the
# same Foundry IQ KB above (endpoint/key/kb fall back to FOUNDRY_IQ_*); set the
# FABRIC_IQ_* overrides only if the ontology lives on a different search service.
# FABRIC_IQ_KS=fabric-sales-ontology          # the fabricOntology/fabricDataAgent knowledge-source name
# FABRIC_IQ_KS_KIND=fabricOntology            # or fabricDataAgent
# FABRIC_IQ_ENDPOINT=                         # optional override (else FOUNDRY_IQ_ENDPOINT)
# FABRIC_IQ_KEY=                              # optional override (else FOUNDRY_IQ_KEY)
# FABRIC_IQ_KB=                               # optional override (else FOUNDRY_IQ_KB)

# --- Work IQ grounding (Path B sibling: ground_work_iq) ---
# Registers ground_work_iq when WORK_IQ_KS is set. Work IQ is permission-aware;
# set WORK_IQ_USER_TOKEN to forward a per-user identity for query-time ACLs.
# WORK_IQ_KS=work-iq-source                   # the workIQ knowledge-source name
# WORK_IQ_KS_KIND=workIQ
# WORK_IQ_USER_TOKEN=                         # optional bearer for x-ms-query-source-authorization
# WORK_IQ_ENDPOINT=                           # optional override (else FOUNDRY_IQ_ENDPOINT)
# WORK_IQ_KEY=                                # optional override (else FOUNDRY_IQ_KEY)
# WORK_IQ_KB=                                 # optional override (else FOUNDRY_IQ_KB)
